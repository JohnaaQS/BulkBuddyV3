@model BulkBuddy.Web.Models.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<section class="auth-shell">
    <div class="auth-card">
        <h1>Login</h1>
        <p>Log in op je BulkBuddy account.</p>

        <form asp-controller="Account" asp-action="Login" method="post" class="auth-form">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="validation-error"></div>

            <div class="form-group">
                <label asp-for="UsernameOrEmail"></label>
                <input asp-for="UsernameOrEmail" class="form-input" />
                <span asp-validation-for="UsernameOrEmail" class="validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password"></label>
                <input asp-for="Password" class="form-input" />
                <span asp-validation-for="Password" class="validation-error"></span>
            </div>

            <button type="submit" class="dashboard-link">Login</button>
        </form>

        <p class="auth-switch">
            Nog geen account?
            <a asp-controller="Account" asp-action="Register">Maak een account aan</a>
        </p>
    </div>
</section>
