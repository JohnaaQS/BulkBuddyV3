@model BulkBuddy.Web.Models.ViewModels.SavedMealsViewModel

@{
    ViewData["Title"] = "Saved Meals";
}

<section class="dashboard-hero">
    <div>
        <h1>Saved Meals</h1>
        <p class="hero-text">Beheer je maaltijdtemplates of voeg er een toe aan vandaag.</p>
    </div>
    <div class="action-list" style="margin-top: 20px;">
        <a asp-controller="Meals" asp-action="NewTemplate" class="dashboard-link">+ Nieuwe template</a>
    </div>
</section>

@if (TempData["Error"] is string error)
{
    <p style="color:red;">@error</p>
}

@{
    var globals  = Model.Meals.Where(m => m.IsGlobal).ToList();
    var privates = Model.Meals.Where(m => !m.IsGlobal).ToList();
}

@* ── Standaard templates ────────────────────────────────────────────────── *@
<h2 style="margin-top: 24px;">Standaard templates</h2>
<section class="dashboard-grid">
    @foreach (var meal in globals)
    {
        <article class="dashboard-card dashboard-card-highlight">
            <p style="font-size:0.8em; color:#888;">Standard</p>
            <h2>@meal.Name</h2>
            <p><strong>Slot:</strong> @meal.MealSlot</p>
            <p><strong>Kcal:</strong> @meal.TotalCalories</p>
            <p><strong>Macro's:</strong> P @meal.ProteinGrams / C @meal.CarbsGrams / F @meal.FatsGrams</p>
            @if (!string.IsNullOrEmpty(meal.IngredientSummary))
            {
                <p><strong>Ingrediënten:</strong> @meal.IngredientSummary</p>
            }
            <div class="action-list" style="margin-top: 12px;">
                <form asp-controller="Meals" asp-action="AddToToday" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@meal.Id" />
                    <button type="submit" class="dashboard-link">Add to today</button>
                </form>
                <form asp-controller="Meals" asp-action="CopyTemplate" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@meal.Id" />
                    <button type="submit" class="dashboard-link">Kopieer naar mijn templates</button>
                </form>
            </div>
        </article>
    }
    @if (!globals.Any())
    {
        <p>Geen standaard templates gevonden.</p>
    }
</section>

@* ── Mijn templates ─────────────────────────────────────────────────────── *@
<h2 style="margin-top: 32px;">Mijn templates</h2>
<section class="dashboard-grid">
    @foreach (var meal in privates)
    {
        <article class="dashboard-card">
            <p style="font-size:0.8em; color:#888;">My template</p>
            <h2>@meal.Name</h2>
            <p><strong>Slot:</strong> @meal.MealSlot</p>
            <p><strong>Kcal:</strong> @meal.TotalCalories</p>
            <p><strong>Macro's:</strong> P @meal.ProteinGrams / C @meal.CarbsGrams / F @meal.FatsGrams</p>
            @if (!string.IsNullOrEmpty(meal.IngredientSummary))
            {
                <p><strong>Ingrediënten:</strong> @meal.IngredientSummary</p>
            }
            <div class="action-list" style="margin-top: 12px;">
                <form asp-controller="Meals" asp-action="AddToToday" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@meal.Id" />
                    <button type="submit" class="dashboard-link">Add to today</button>
                </form>
                <a asp-controller="Meals" asp-action="EditTemplate" asp-route-id="@meal.Id" class="dashboard-link">Bewerken</a>
                <form asp-controller="Meals" asp-action="DeleteTemplate" method="post"
                      onsubmit="return confirm('Template verwijderen?');">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@meal.Id" />
                    <button type="submit" class="dashboard-link">Verwijderen</button>
                </form>
            </div>
        </article>
    }
    @if (!privates.Any())
    {
        <p>Je hebt nog geen eigen templates. Maak er een aan of kopieer een standaard template.</p>
    }
</section>
