@model BulkBuddy.Web.Models.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<section class="dashboard-hero">
    <div>
        <h1>Dashboard</h1>
        @* Fix #6: WelcomeMessage weggehaald uit Business — View bouwt de string zelf *@
        <p class="hero-text">Welkom terug, @Model.Username. Je dashboard staat klaar voor je @Model.GoalPhase-fase.</p>
    </div>
</section>

<section class="dashboard-grid">
    <article class="dashboard-card dashboard-card-highlight">
        <h2>Profiel</h2>
        <p><strong>Gebruikersnaam:</strong> @Model.Username</p>
        <p><strong>Lengte:</strong> @Model.HeightCm cm</p>
        <p><strong>Gewicht:</strong> @Model.WeightKg kg</p>
    </article>

    <article class="dashboard-card">
        <h2>Doel</h2>
        <p><strong>Fase:</strong> @Model.GoalPhase</p>
        <p><strong>Doelgewicht:</strong> @Model.TargetWeightKg kg</p>
        @* Fix #6: GoalSummary weggehaald uit Business — View bouwt de string zelf *@
        <p>Je huidige gewicht is @Model.WeightKg kg en je doelgewicht is @Model.TargetWeightKg kg tijdens je @Model.GoalPhase-fase.</p>
    </article>

    <article class="dashboard-card">
        <h2>Voeding</h2>
        <p><strong>Dagelijks calorie target:</strong></p>
        <div class="big-number">@Model.CalorieTarget kcal</div>
    </article>

    <article class="dashboard-card">
        <h2>Vandaag</h2>
        <p><strong>Gelogde meals:</strong> @Model.MealsLoggedToday</p>
        <p><strong>Totaal gegeten:</strong> @Model.CaloriesToday kcal</p>
        <p><strong>Dagdoel:</strong> @Model.CalorieTarget kcal</p>
        <p><strong>Nog te gaan:</strong> @Model.RemainingCalories kcal</p>

        <div class="progress-wrapper">
            <div class="progress-bar">
                <div class="progress-fill" style="width:@Model.CalorieProgressPercent%;"></div>
            </div>
            <p class="progress-text">@Model.CalorieProgressPercent% van je calorie target bereikt</p>
        </div>
    </article>

    <article class="dashboard-card">
        <h2>Snelle acties</h2>
        <div class="action-list">
            <a asp-controller="Dashboard" asp-action="Index" class="dashboard-link">Dashboard verversen</a>
            <a asp-controller="Meals" asp-action="Index" class="dashboard-link">Ga naar Meals</a>
        </div>
    </article>
</section>
